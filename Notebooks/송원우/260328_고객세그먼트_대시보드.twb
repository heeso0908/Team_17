            <column caption='Individual Cvr' datatype='real' name='[individual_cvr]' role='measure' type='quantitative' />
            <column caption='Is Vip' datatype='boolean' name='[is_vip]' role='dimension' type='nominal' />
            <column caption='Mobile' datatype='real' name='[mobile]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_4316049118572574]' derivation='None' name='[none:Calculation_4316049118572574:nk]' pivot='key' type='nominal' />
            <column caption='Offer Type' datatype='string' name='[offer_type]' role='dimension' type='nominal' />
            <column caption='Social' datatype='real' name='[social]' role='measure' type='quantitative' />
            <column caption='Total Amount' datatype='real' name='[total_amount]' role='measure' type='quantitative' />
            <column caption='Web' datatype='real' name='[web]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (C_고객 세그먼트) 1]'>
