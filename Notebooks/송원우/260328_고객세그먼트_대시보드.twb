          <datasource-dependencies datasource='federated.0stk40j0604siw10fyntq1w2yxxr'>
            <column caption='C_고객 세그먼트' datatype='string' name='[Calculation_4316049020547072]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_amount] = 0 THEN &quot;첫 결제 유도&quot;&#10;ELSEIF ISNULL([individual_cvr]) OR [individual_cvr] = 0 THEN &quot;무반응/이탈주의&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &gt;= 60 THEN &quot;반응형 VIP&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &lt; 60 THEN &quot;안정적 VIP&quot;&#10;ELSEIF NOT [is_vip] AND [individual_cvr] &gt;= 60 AND [total_amount] &gt; 72 THEN &quot;성장 유망주&quot;&#10;ELSE &quot;알뜰 실속객&quot;&#10;END' />
            </column>
            <column caption='C_마케팅 액션 가이드' datatype='string' name='[Calculation_4316049025400836]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Calculation_4316049020547072]&#10;WHEN &quot;반응형 VIP&quot; THEN &#10;    &quot;🎁 최우선 타겟: 신상품 얼리 액세스 및 고부가가치 BOGO 쿠폰 발송&quot; + CHAR(10) + &#10;    &quot;👉 반응 속도가 빠르므로 한정 수량 오퍼가 효과적입니다.&quot;&#10;&#10;WHEN &quot;안정적 VIP&quot; THEN &#10;    &quot;💎 프리미엄 관리: 무료 배송, 전담 상담 등 서비스형 혜택 집중&quot; + CHAR(10) + &#10;    &quot;👉 잦은 광고 문자는 피로도를 높일 수 있으니 정중한 톤을 유지하세요.&quot;&#10;&#10;WHEN &quot;성장 유망주&quot; THEN &#10;    &quot;🚀 VIP 승급 유도: 업셀링(Up-sell) 오퍼 발송&quot; + CHAR(10) + &#10;    &quot;👉 &apos;조금만 더 구매하면 VIP 혜택&apos;을 강조하여 객단가를 높이세요.&quot;&#10;&#10;WHEN &quot;알뜰 실속객&quot; THEN &#10;    &quot;🌱 활동성 유지: 박리다매형 오퍼 및 출석 체크 이벤트&quot; + CHAR(10) + &#10;    &quot;👉 소액 다빈도 결제를 유도하여 방문 빈도를 높이는 것이 핵심입니다.&quot;&#10;&#10;WHEN &quot;무반응/이탈주의&quot; THEN &#10;    &quot;⚠️ 채널 전략 변경: 기존 채널(SMS 등) 외 채널 전환 고려&quot; + CHAR(10) + &#10;    &quot;👉 파격적인 &apos;리워드 쿠폰&apos;이나 이메일/앱 푸시로 재방문을 유도하세요.&quot;&#10;&#10;WHEN &quot;첫 결제 유도&quot; THEN &#10;    &quot;✨ 전환율 극대화: &apos;첫 구매 100원 딜&apos; 등 파격적인 웰컴 오퍼&quot; + CHAR(10) + &#10;    &quot;👉 브랜드 신뢰도를 높일 수 있는 베스트 리뷰 노출을 병행하세요.&quot;&#10;&#10;ELSE &quot;기본 대응: 표준 마케팅 가이드라인을 준수하세요.&quot;&#10;END' />
            </column>
            <column caption='Individual Cvr' datatype='real' name='[individual_cvr]' role='measure' type='quantitative' />
            <column caption='Is Vip' datatype='boolean' name='[is_vip]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_4316049025400836]' derivation='None' name='[none:Calculation_4316049025400836:nk]' pivot='key' type='nominal' />
            <column caption='Total Amount' datatype='real' name='[total_amount]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (C_고객 세그먼트) 1]'>
            <groupfilter function='empty-level' member='[Calculation_4316049020547072]' user:ui-action-filter='[Action2_29AB36CB487A4424B4E06E4DC11BEB2C]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
