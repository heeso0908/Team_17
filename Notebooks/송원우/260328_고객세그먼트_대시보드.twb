          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (Age Group,Is Vip)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action2_6BA3A63520D54AB5A1DD5B7A4ECCA062]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[age_group]' />
              <groupfilter function='level-members' level='[is_vip]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (Gender Mapped,Is Vip)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action5_3A0D4F6E2EEA40E9868943899B0598B2]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[gender_mapped]' />
              <groupfilter function='level-members' level='[is_vip]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (Income Group,Is Vip)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action4_CDF3455C532B4FB1A49BC981C81E375E]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[income_group]' />
              <groupfilter function='level-members' level='[is_vip]' />
            </groupfilter>
          </filter>
          <slices>
