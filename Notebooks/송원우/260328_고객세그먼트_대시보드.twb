    <worksheet name='전체 ARPPU'>
      <table>
        <view>
          <datasources>
            <datasource caption='260328_master_customers_final' name='federated.0stk40j0604siw10fyntq1w2yxxr' />
          </datasources>
          <datasource-dependencies datasource='federated.0stk40j0604siw10fyntq1w2yxxr'>
            <column caption='C_ARPPU' datatype='real' default-format='c&quot;$&quot;#,##0.0;-&quot;$&quot;#,##0.0' name='[Calculation_4128100975185921]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([total_amount]) / COUNTD(IIF([total_amount] &gt; 0, [customer_id], NULL))' />
            </column>
