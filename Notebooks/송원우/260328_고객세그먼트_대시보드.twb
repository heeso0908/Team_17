    <worksheet name='시뮬레이터 결과'>
      <table>
        <view>
          <datasources>
            <datasource caption='260328_master_customers_final' name='federated.0stk40j0604siw10fyntq1w2yxxr' />
            <datasource caption='매개 변수' name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='P_Input_Age' datatype='integer' name='[매개 변수 1]' param-domain-type='range' role='measure' type='quantitative' value='45'>
              <calculation class='tableau' formula='45' />
              <range max='100' min='0' />
            </column>
            <column caption='P_Input_Gender' datatype='string' name='[매개 변수 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;남성&quot;'>
              <calculation class='tableau' formula='&quot;남성&quot;' />
            </column>
            <column caption='P_Input_Income_Value' datatype='integer' datatype-customized='true' name='[매개 변수 4]' param-domain-type='any' role='measure' type='quantitative' value='180000'>
              <calculation class='tableau' formula='180000' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0stk40j0604siw10fyntq1w2yxxr'>
            <column caption='C_Global_Spending_33' datatype='real' name='[C_Global_Income_33(복사본)(복사본)_4316049101131794]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([total_amount], 0.33) }' />
            </column>
            <column caption='C_Global_Income_66' datatype='real' name='[C_Global_Income_33(복사본)_4316049101094929]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([income], 0.66) }' />
            </column>
            <column caption='C_Global_Spending_66' datatype='real' name='[C_Global_Spending_33(복사본)_4316049101373459]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([total_amount], 0.66) }' />
            </column>
            <column caption='C_고객 세그먼트' datatype='string' name='[Calculation_4316049020547072]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_amount] = 0 THEN &quot;첫 결제 유도&quot;&#10;ELSEIF ISNULL([individual_cvr]) OR [individual_cvr] = 0 THEN &quot;무반응/이탈주의&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &gt;= 60 THEN &quot;반응형 VIP&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &lt; 60 THEN &quot;안정적 VIP&quot;&#10;ELSEIF NOT [is_vip] AND [individual_cvr] &gt;= 60 AND [total_amount] &gt; 72 THEN &quot;성장 유망주&quot;&#10;ELSE &quot;알뜰 실속객&quot;&#10;END' />
            </column>
            <column caption='C_Global_Income_33' datatype='real' name='[Calculation_4316049100963856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : PERCENTILE([income], 0.33) }' />
            </column>
            <column caption='C_Sim_Input_Age_Match' datatype='string' name='[Calculation_4316049101508628]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IFNULL(&#10;    IF [Parameters].[매개 변수 1] &lt; 20 THEN &quot;20세 미만&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 30 THEN &quot;20대&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 40 THEN &quot;30대&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 50 THEN &quot;40대&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 60 THEN &quot;50대&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 70 THEN &quot;60대&quot;&#10;    ELSEIF [Parameters].[매개 변수 1] &lt; 80 THEN &quot;70대&quot;&#10;    ELSE &quot;80대 이상&quot;&#10;    END,&#10;&quot;데이터 없음&quot;)' />
            </column>
            <column caption='C_Sim_Input_Income_Match' datatype='string' name='[Calculation_4316049101721621]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IFNULL(&#10;    IF [Parameters].[매개 변수 4] &lt; 50000 THEN &quot;30K-50K&quot;&#10;    ELSEIF [Parameters].[매개 변수 4] &lt; 70000 THEN &quot;50K-70K&quot;&#10;    ELSEIF [Parameters].[매개 변수 4] &lt; 90000 THEN &quot;70K-90K&quot;&#10;    ELSEIF [Parameters].[매개 변수 4] &lt; 110000 THEN &quot;90K-110K&quot;&#10;    ELSE &quot;110K 이상&quot;&#10;    END, &#10;&quot;데이터 없음&quot;)' />
            </column>
            <column caption='C_Sim_Input_Income_Tier' datatype='string' name='[Calculation_4316049102254102]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[매개 변수 4] &gt;= [C_Global_Income_33(복사본)_4316049101094929] THEN &quot;고소득&quot;&#10;ELSEIF [Parameters].[매개 변수 4] &gt;= [Calculation_4316049100963856] THEN &quot;중소득&quot;&#10;ELSE &quot;저소득&quot;&#10;END' />
            </column>
            <column caption='C_Sim_Group_Spending_Median' datatype='real' name='[Calculation_4316049102446615]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [gender_mapped], [age_group], [income_group] : MEDIAN([total_amount]) }' />
            </column>
            <column caption='C_Sim_Spending_Tier' datatype='string' name='[Calculation_4316049102667800]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_4316049102446615] &gt;= [C_Global_Spending_33(복사본)_4316049101373459] THEN &quot;고지출 군&quot;&#10;ELSEIF [Calculation_4316049102446615] &gt;= [C_Global_Income_33(복사본)(복사본)_4316049101131794] THEN &quot;중지출 군&quot;&#10;ELSE &quot;저지출 군&quot;&#10;END' />
            </column>
            <column caption='C_Sim_Mode_Offer' datatype='string' name='[Calculation_4316049102729241]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED [gender_mapped], [age_group], [income_group] : &#10;    MAX(&#10;        IF { FIXED [gender_mapped], [age_group], [income_group], [offer_type] : COUNT([customer_id]) }&#10;        = &#10;        { FIXED [gender_mapped], [age_group], [income_group] : MAX({ FIXED [gender_mapped], [age_group], [income_group], [offer_type] : COUNT([customer_id]) }) }&#10;        THEN [offer_type]&#10;        END&#10;    )&#10;}' />
            </column>
            <column caption='C_Sim_Mode_Channel' datatype='string' name='[Calculation_4316049104973850]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED [gender_mapped], [age_group], [income_group] : &#10;    IF SUM([email]) &gt;= SUM([mobile]) AND SUM([email]) &gt;= SUM([social]) AND SUM([email]) &gt;= SUM([web]) THEN &quot;Email&quot;&#10;    ELSEIF SUM([mobile]) &gt;= SUM([email]) AND SUM([mobile]) &gt;= SUM([social]) AND SUM([mobile]) &gt;= SUM([web]) THEN &quot;Mobile&quot;&#10;    ELSEIF SUM([social]) &gt;= SUM([email]) AND SUM([social]) &gt;= SUM([mobile]) AND SUM([social]) &gt;= SUM([web]) THEN &quot;Social&quot;&#10;    ELSE &quot;Web&quot;&#10;    END&#10;}' />
            </column>
            <column caption='C_Sim_Final_Report_Display' datatype='string' name='[Calculation_4316049107304475]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;🎯 시뮬레이션 결과 리포트&quot; + CHAR(10) +&#10;&quot;--------------------------------------------------&quot; + CHAR(10) +&#10;&quot;👤 분석 타겟: &quot; + IFNULL([Parameters].[매개 변수 2], &quot;선택 안됨&quot;) + &quot; / &quot; + &#10;    [Calculation_4316049101508628] + &quot; / &quot; + &#10;    [Calculation_4316049101721621] + CHAR(10) +&#10;&quot;--------------------------------------------------&quot; + CHAR(10) +&#10;&quot;⚖️ 데이터 팩트 체크 (중앙값 기준)&quot; + CHAR(10) +&#10;&quot; • 소득 수준: &quot; + IFNULL([Calculation_4316049102254102], &quot;데이터 없음&quot;) + CHAR(10) +&#10;&quot; • 지출 체급: &quot; + IFNULL([Calculation_4316049102667800], &quot;데이터 없음&quot;) + CHAR(10) +&#10;&quot;--------------------------------------------------&quot; + CHAR(10) +&#10;&quot;🚀 마케팅 실행 전략 (최빈값 기반)&quot; + CHAR(10) +&#10;&quot; • 추천 오퍼: &quot; + IFNULL([Calculation_4316049102729241], &quot;데이터 없음&quot;) + CHAR(10) +&#10;&quot; • 최적 채널: &quot; + IFNULL([Calculation_4316049104973850], &quot;데이터 없음&quot;) + CHAR(10) +&#10;&quot;--------------------------------------------------&quot; + CHAR(10) +&#10;&quot;📊 분석 근거: 해당 집단 실제 데이터 &quot; + &#10;    IF ZN({ FIXED [gender_mapped], [age_group], [income_group] : COUNT([customer_id]) }) = 0 &#10;    THEN &quot;없음&quot; &#10;    ELSE STR({ FIXED [gender_mapped], [age_group], [income_group] : COUNT([customer_id]) }) + &quot;건 기준&quot; &#10;    END' />
            </column>
            <column caption='C_Sim_Global_Result' datatype='string' name='[Calculation_4316049118572574]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{ FIXED : &#10;    MAX(&#10;        IF [gender_mapped] = [Parameters].[매개 변수 2] &#10;        AND [age_group] = [Calculation_4316049101508628] &#10;        AND [income_group] = [Calculation_4316049101721621]&#10;        THEN [Calculation_4316049107304475]&#10;        END&#10;    )&#10;}' />
            </column>
            <column caption='Age Group' datatype='string' name='[age_group]' role='dimension' type='nominal' />
            <column caption='Customer Id' datatype='string' name='[customer_id]' role='dimension' type='nominal' />
            <column caption='Email' datatype='real' name='[email]' role='measure' type='quantitative' />
            <column caption='Gender Mapped' datatype='string' name='[gender_mapped]' role='dimension' type='nominal' />
            <column caption='Income' datatype='real' name='[income]' role='measure' type='quantitative' />
