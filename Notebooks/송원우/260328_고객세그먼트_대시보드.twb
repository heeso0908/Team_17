    <worksheet name='전략 산점도'>
      <table>
        <view>
          <datasources>
            <datasource caption='260328_master_customers_final' name='federated.0stk40j0604siw10fyntq1w2yxxr' />
          </datasources>
          <datasource-dependencies datasource='federated.0stk40j0604siw10fyntq1w2yxxr'>
            <column caption='C_고객 세그먼트' datatype='string' name='[Calculation_4316049020547072]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_amount] = 0 THEN &quot;첫 결제 유도&quot;&#10;ELSEIF ISNULL([individual_cvr]) OR [individual_cvr] = 0 THEN &quot;무반응/이탈주의&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &gt;= 60 THEN &quot;반응형 VIP&quot;&#10;ELSEIF [is_vip] AND [individual_cvr] &lt; 60 THEN &quot;안정적 VIP&quot;&#10;ELSEIF NOT [is_vip] AND [individual_cvr] &gt;= 60 AND [total_amount] &gt; 72 THEN &quot;성장 유망주&quot;&#10;ELSE &quot;알뜰 실속객&quot;&#10;END' />
            </column>
            <column caption='C_매출액 로그화' datatype='real' name='[Calculation_4316049023578115]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='LOG([total_amount] + 1)' />
            </column>
            <column caption='Customer Id' datatype='string' name='[customer_id]' role='dimension' type='nominal' />
            <column caption='Individual Cvr' datatype='real' name='[individual_cvr]' role='measure' type='quantitative' />
            <column caption='Is Vip' datatype='boolean' name='[is_vip]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_4316049020547072]' derivation='None' name='[none:Calculation_4316049020547072:nk]' pivot='key' type='nominal' />
            <column-instance column='[customer_id]' derivation='None' name='[none:customer_id:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_4316049023578115]' derivation='Sum' name='[sum:Calculation_4316049023578115:qk]' pivot='key' type='quantitative' />
            <column-instance column='[individual_cvr]' derivation='Sum' name='[sum:individual_cvr:qk]' pivot='key' type='quantitative' />
            <column caption='Total Amount' datatype='real' name='[total_amount]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0stk40j0604siw10fyntq1w2yxxr].[Action (C_고객 세그먼트) 1]'>
            <groupfilter function='level-members' level='[Calculation_4316049020547072]' user:ui-action-filter='[Action3_F2CCE5D0E6CE4642BA9FA0DAD783DD08]' user:ui-enumeration='all' user:ui-marker='enumerate' />
