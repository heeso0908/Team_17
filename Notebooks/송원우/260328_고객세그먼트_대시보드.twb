            <column caption='Mobile' datatype='real' name='[mobile]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_4316049118572574]' derivation='None' name='[none:Calculation_4316049118572574:nk]' pivot='key' type='nominal' />
