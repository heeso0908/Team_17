            <encodings>
              <text column='[federated.0stk40j0604siw10fyntq1w2yxxr].[none:Calculation_4316049025400836:nk]' />
            </encodings>
            <customized-label>
              <formatted-text>
                <run fontname='Tableau Semibold' fontsize='12'>&lt;</run>
                <run fontname='Tableau Semibold' fontsize='12'>[federated.0stk40j0604siw10fyntq1w2yxxr].[none:Calculation_4316049025400836:nk]</run>
                <run fontname='Tableau Semibold' fontsize='12'>&gt;</run>
              </formatted-text>
            </customized-label>
            <style>
              <style-rule element='cell'>
                <format attr='vertical-align' value='center' />
                <format attr='text-align' value='left' />
